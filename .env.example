# =========================================================================
# Ambience TutorsFlow™ Consolidated Environment Variable Template (.env.example)
# Soli Deo Gloria — Production-Ready Core Settings
# =========================================================================

# -------------------------------------------------------------------------
# 1. FRONTEND ENVIRONMENT CONFIGURATIONS (Vite client-side)
# Save these in frontend/.env for local work, or set them in Vercel
# -------------------------------------------------------------------------

# The live, public API endpoint URL of your Supabase Project
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# The client-safe, public Anonymous access token for your Supabase Project
VITE_SUPABASE_ANON_KEY=your_public_anon_key_string

# -------------------------------------------------------------------------
# 2. BACKEND ENVIRONMENT CONFIGURATIONS (Node.js/Express server-side)
# Save these in backend/.env for local work, or set them in Railway/Render
# -------------------------------------------------------------------------

# Port on which the Express REST API runs in production (Render/Railway bind this automatically)
PORT=5000

# Client front-end URI where the callback handler redirects the Tutor's web browser after authorization
FRONTEND_URL=http://localhost:5173

# Live Zoom App Credentials (OAuth 2.0 Credentials from Zoom App Marketplace)
ZOOM_CLIENT_ID=your_zoom_client_id_here
ZOOM_CLIENT_SECRET=your_zoom_client_secret_here

# The live OAuth redirect URI configured inside your Zoom Marketplace dashboard
# Matches the callback route exposed by your Express backend server
ZOOM_REDIRECT_URI=http://localhost:5000/api/zoom/callback
