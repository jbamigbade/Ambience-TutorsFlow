# Zoom API Configuration Placeholders
# Do not commit raw secrets to version control. Replace these with actual values in production.

PORT=5000
ZOOM_CLIENT_ID=YOUR_ZOOM_CLIENT_ID_PLACEHOLDER
ZOOM_CLIENT_SECRET=YOUR_ZOOM_CLIENT_SECRET_PLACEHOLDER
ZOOM_REDIRECT_URI=http://localhost:5000/api/zoom/callback

# Client frontend URL to redirect to after successful OAuth callback
FRONTEND_URL=http://localhost:5173
